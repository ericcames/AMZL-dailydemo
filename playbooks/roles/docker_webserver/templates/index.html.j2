  <title>Ansible Automation Platform — Amazon Linux 2023 Daily Demo</title>
  <style>
    :root { color-scheme: light dark; }
    body {
      font-family: "Red Hat Text", -apple-system, Segoe UI, Roboto, sans-serif;
      margin: 0; padding: 2.5rem 1.25rem; line-height: 1.55;
      background: #f4f4f4; color: #151515;
    }
    @media (prefers-color-scheme: dark) {
      body { background: #1b1b1d; color: #e0e0e0; }
      .card { background: #292929 !important; }
    }
    .wrap { max-width: 760px; margin: 0 auto; }
    .card {
      background: #fff; border-radius: 12px; padding: 2rem 2.25rem;
      box-shadow: 0 2px 14px rgba(0,0,0,.12); margin-bottom: 1.5rem;
    }
    h1 { margin: 0 0 .25rem; font-size: 1.7rem; }
    .logo { display: block; margin: 0 0 1rem; }
    .logo svg { height: 48px; width: auto; }
    .badge {
      display: inline-block; background: #ee0000; color: #fff;
      padding: .15rem .6rem; border-radius: 999px; font-size: .78rem;
      font-weight: 600; letter-spacing: .02em;
    }
    dl { display: grid; grid-template-columns: max-content 1fr; gap: .35rem 1rem; margin: 1.1rem 0 0; }
    dt { font-weight: 600; opacity: .7; }
    code { font-family: "Red Hat Mono", ui-monospace, monospace; }
    .foot { font-size: .85rem; opacity: .7; text-align: center; }
    .destruct { color: #ee0000; font-weight: 600; }
  </style>
