---
# ansible-lint config for the CI lint gate (.github/workflows/lint.yml).
# Runs offline (no Automation Hub token in CI); certified/community collections
# are not installed, so declare the modules/roles we use from them — otherwise
# syntax-check fails with "couldn't resolve module/action". Locally they resolve
# because the collections are installed; CI is the clean case these mocks cover.
profile: basic

mock_modules:
  - ansible.controller.host
  - ansible.controller.group
  - community.docker.docker_image
  - community.docker.docker_container
  - ansible.posix.firewalld
  - ansible.posix.authorized_key

mock_roles:
  - infra.aap_configuration.dispatch

exclude_paths:
  - collections/ansible_collections/   # vendored collections, if any
  - context/                            # ansible-builder generated EE context
  - .github/

skip_list:
  # Patching and hardening intentionally bring packages to the latest version.
  - package-latest
