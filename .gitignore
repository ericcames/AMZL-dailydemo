# Ansible — installed collections (declared in collections/requirements.yml)
collections/ansible_collections/

# Ansible — local cache dirs created by ansible / ansible-lint
.ansible/

# Ansible — vault password files and local secrets
.vault_pass
.vault_password
*.vault_pass

# direnv-loaded local environment, if you use direnv for per-developer secrets.
.envrc

# Local dev environment secrets — never commit. Holds the real AAP + AWS +
# devops credentials and must stay out of this public repo. No leading slash, so
# this matches dev-environment.sh in ANY directory (e.g. docs/dev-environment.sh).
# The committed template docs/dev-environment.sh.example is a different filename
# and is NOT matched.
dev-environment.sh

# Terraform — local working dir, state, plans, provider cache. Remote state
# lives in S3; the .terraform.lock.hcl IS committed (see terraform/.gitignore).
terraform/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
override.tf
override.tf.json

# Claude Code per-project state (memory, transcripts, settings) — ignored,
# EXCEPT repo-based skills, which ship with the repo.
.claude/*
!.claude/skills/

# OS / editor cruft
.DS_Store
*.swp
*~
__pycache__/
*.py[cod]

# ansible-builder generated EE build context (derived artifact)
context/
